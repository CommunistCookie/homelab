# WireGuard VPN Configuration (sanitized example)
# Running on QNAP TS-212 NAS
# Replace values in <> with your own

[Interface]
PrivateKey = <YOUR_PRIVATE_KEY>
Address = 10.0.0.1/24
ListenPort = 51820
DNS = 10.0.0.2  # Points to Pi-hole for DNS filtering over VPN

# Firewall rules to allow VPN traffic and forwarding
PostUp = iptables -A FORWARD -i wg0 -j ACCEPT; iptables -t nat -A POSTROUTING -o eth0 -j MASQUERADE
PostDown = iptables -D FORWARD -i wg0 -j ACCEPT; iptables -t nat -D POSTROUTING -o eth0 -j MASQUERADE

# Example peer (remote device connecting in)
[Peer]
PublicKey = <PEER_PUBLIC_KEY>
AllowedIPs = 10.0.0.2/32
